# FinanceFlow — Konfigurasi

# ── Google OAuth 2.0 ──────────────────────────────────────────
# Buat di: https://console.cloud.google.com
# APIs & Services → Credentials → Create Credentials → OAuth 2.0 Client ID
# Application type: Web application
# Authorized redirect URIs: http://localhost:3000/auth/callback
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# ── Session ───────────────────────────────────────────────────
# String acak, bisa bebas
SESSION_SECRET=ganti-dengan-string-acak-panjang

# ── Groq API (untuk transkripsi suara via Whisper) ────────────
# Daftar gratis di: https://console.groq.com
# Key gratis, cepat, bagus untuk Bahasa Indonesia
GROQ_API_KEY=your_groq_api_key_here

# ── Server ────────────────────────────────────────────────────
PORT=3000
